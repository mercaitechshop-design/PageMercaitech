# Mercaitech — Ejemplo de configuración
# Copia como api/config.local.php y completa los valores reales
# NUNCA subas config.local.php a un repositorio público

# ── Base de datos MySQL ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mercaitech
DB_USER=mercaitech
DB_PASS=tu_password_aqui

# ── Aplicación ─────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:8080
JWT_SECRET=genera_un_secreto_aleatorio_aqui

# ── Email Gmail SMTP ───────────────────────────────────────────
# Requiere Contraseña de aplicación (NO tu contraseña de Gmail)
# Ver: myaccount.google.com → Seguridad → Verificación en 2 pasos → Contraseñas de app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
MAIL_FROM_EMAIL=tu_correo@gmail.com
MAIL_FROM_NAME=Mercaitech

# ── WhatsApp ────────────────────────────────────────────────────
WA_NUMBER=57XXXXXXXXXX
